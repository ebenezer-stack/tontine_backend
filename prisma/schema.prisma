generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model contributions {
  id               BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tontine_id       BigInt    @db.UnsignedBigInt
  user_id          BigInt    @db.UnsignedBigInt
  amount           Decimal   @db.Decimal(12, 2)
  penalty_amount   Decimal   @default(0.00) @db.Decimal(12, 2)
  due_date         DateTime  @db.Timestamp(0)
  paid_date        DateTime? @db.Timestamp(0)
  status           String    @default("unpaid")
  payment_method   String?
  payment_id       String?
  payment_provider String?
  payment_details  Json?
  reference        String?   @unique(map: "contributions_reference_unique")
  notes            String?   @db.Text
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)

  @@index([due_date], map: "contributions_due_date_index")
  @@index([tontine_id, user_id, status], map: "contributions_tontine_id_user_id_status_index")
  @@index([user_id], map: "contributions_user_id_foreign")
}

model guarantors {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id      BigInt    @db.UnsignedBigInt
  name         String
  phone        String
  address      String?   @db.Text
  id_card_path String?
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)

  @@index([user_id], map: "guarantors_user_id_foreign")
}

model members {
  id                    BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  tontine_id            BigInt         @db.UnsignedBigInt
  user_id               BigInt         @db.UnsignedBigInt
  role                  members_role   @default(member)
  joined_at             DateTime       @db.Timestamp(0)
  left_at               DateTime?      @db.Timestamp(0)
  status                members_status @default(active)
  has_received_item     Boolean        @default(false)
  trust_score           Int            @default(100)
  penalty_frozen_until  DateTime?      @db.Timestamp(0)
  daily_expected_amount Decimal        @default(1200.00) @db.Decimal(12, 2)
  total_contributed     Decimal        @default(0.00) @db.Decimal(12, 2)
  total_penalties       Decimal        @default(0.00) @db.Decimal(12, 2)
  payout_order          Int?
  created_at            DateTime?      @db.Timestamp(0)
  updated_at            DateTime?      @db.Timestamp(0)

  @@unique([tontine_id, user_id], map: "members_tontine_id_user_id_unique")
  @@index([tontine_id, status], map: "members_tontine_id_status_index")
  @@index([user_id], map: "members_user_id_foreign")
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String
  batch     Int
}

model notifications {
  id         BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt             @db.UnsignedBigInt
  tontine_id BigInt?            @db.UnsignedBigInt
  type       notifications_type
  title      String
  message    String             @db.Text
  data       Json?
  read_at    DateTime?          @db.Timestamp(0)
  created_at DateTime?          @db.Timestamp(0)
  updated_at DateTime?          @db.Timestamp(0)

  @@index([tontine_id], map: "notifications_tontine_id_foreign")
  @@index([user_id, read_at], map: "notifications_user_id_read_at_index")
}

model otps {
  id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt?   @db.UnsignedBigInt
  phone       String    @db.VarChar(20)
  code        String    @db.VarChar(10)
  attempts    Int       @default(0)
  expires_at  DateTime  @db.Timestamp(0)
  verified_at DateTime? @db.Timestamp(0)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)

  @@index([phone, code], map: "otps_phone_code_index")
  @@index([user_id], map: "otps_user_id_foreign")
}

model password_reset_tokens {
  email      String    @id
  token      String
  created_at DateTime? @db.Timestamp(0)
}

model payments {
  id               BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  contribution_id  BigInt          @db.UnsignedBigInt
  user_id          BigInt          @db.UnsignedBigInt
  amount           Decimal         @db.Decimal(12, 2)
  payment_method   String
  reference        String?
  proof_image      String?
  status           payments_status @default(pending)
  rejection_reason String?
  created_at       DateTime?       @db.Timestamp(0)
  updated_at       DateTime?       @db.Timestamp(0)

  @@index([contribution_id], map: "payments_contribution_id_foreign")
  @@index([user_id], map: "payments_user_id_foreign")
}

model payouts {
  id             BigInt         @id @default(autoincrement()) @db.UnsignedBigInt
  tontine_id     BigInt         @db.UnsignedBigInt
  beneficiary_id BigInt         @db.UnsignedBigInt
  amount         Decimal        @db.Decimal(12, 2)
  scheduled_date DateTime       @db.Timestamp(0)
  completed_date DateTime?      @db.Timestamp(0)
  status         payouts_status @default(pending)
  order          Int
  notes          String?        @db.Text
  created_at     DateTime?      @db.Timestamp(0)
  updated_at     DateTime?      @db.Timestamp(0)

  @@unique([tontine_id, beneficiary_id], map: "payouts_tontine_id_beneficiary_id_unique")
  @@index([beneficiary_id], map: "payouts_beneficiary_id_foreign")
  @@index([tontine_id, status], map: "payouts_tontine_id_status_index")
} 

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tokenable_type String
  tokenable_id   BigInt    @db.UnsignedBigInt
  name           String
  token          String    @unique(map: "personal_access_tokens_token_unique") @db.VarChar(80)
  abilities      String?   @db.Text
  last_used_at   DateTime? @db.Timestamp(0)
  expires_at     DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  @@index([tokenable_type, tokenable_id], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
}

model sessions {
  id            String  @id
  user_id       BigInt? @db.UnsignedBigInt
  ip_address    String? @db.VarChar(45)
  user_agent    String? @db.Text
  payload       String  @db.LongText
  last_activity Int

  @@index([last_activity], map: "sessions_last_activity_index")
  @@index([user_id], map: "sessions_user_id_index")
}

model tontine_invitations {
  id              BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  tontine_id      BigInt    @db.UnsignedBigInt
  code            String    @unique(map: "tontine_invitations_code_unique")
  is_used         Boolean   @default(false)
  used_by_user_id BigInt?   @db.UnsignedBigInt
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)

  @@index([tontine_id], map: "tontine_invitations_tontine_id_foreign")
  @@index([used_by_user_id], map: "tontine_invitations_used_by_user_id_foreign")
}

model tontines {
  id                  BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  creator_id          BigInt                @db.UnsignedBigInt
  name                String
  description         String?               @db.Text
  contribution_amount Decimal               @db.Decimal(12, 2)
  item_price          Decimal               @default(500000.00) @db.Decimal(12, 2)
  frequency           tontines_frequency
  member_count        Int
  start_date          DateTime              @db.Timestamp(0)
  end_date            DateTime?             @db.Timestamp(0)
  payout_order        tontines_payout_order @default(sequential)
  late_penalty_amount Decimal               @default(0.00) @db.Decimal(12, 2)
  penalty_type        tontines_penalty_type @default(fixed)
  grace_period_days   Int                   @default(0)
  status              tontines_status       @default(pending)
  code                String                @unique(map: "tontines_code_unique")
  image_url           String?
  deleted_at          DateTime?             @db.Timestamp(0)
  created_at          DateTime?             @db.Timestamp(0)
  updated_at          DateTime?             @db.Timestamp(0)

  @@index([creator_id, status], map: "tontines_creator_id_status_index")
}

model users {
  id                BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  phone             String           @unique(map: "users_phone_unique")
  name              String?
  email             String?          @unique(map: "users_email_unique")
  password          String?
  avatar_url        String?
  verified_at       DateTime?        @db.Timestamp(0)
  email_verified_at DateTime?        @db.Timestamp(0)
  role              users_role       @default(member)
  kyc_status        users_kyc_status @default(pending)
  kyc_verified_at   DateTime?        @db.Timestamp(0)
  kyc_document_url  String?
  kyc_selfie_url    String?
  is_active         Boolean          @default(true)
  remember_token    String?          @db.VarChar(100)
  created_at        DateTime?        @db.Timestamp(0)
  updated_at        DateTime?        @db.Timestamp(0)

  @@index([phone], map: "users_phone_index")
}

enum members_role {
  admin
  treasurer
  member
}

enum notifications_type {
  payment_reminder
  payment_received
  late_alert
  payout_scheduled
  payout_completed
  member_joined
  member_left
  tontine_created
  payment_approved
  payment_rejected
  contribution_received
}

enum members_status {
  active
  inactive
  suspended
}

enum payouts_status {
  pending
  scheduled
  completed
  failed
}

enum tontines_frequency {
  daily
  weekly
  monthly
}

enum payments_status {
  pending
  approved
  rejected
}

enum users_role {
  admin
  member
}

enum users_kyc_status {
  pending
  verified
  rejected
}

enum tontines_payout_order {
  manual
  random
  sequential
}

enum tontines_penalty_type {
  fixed
  percentage
}

enum tontines_status {
  pending
  active
  completed
  cancelled
}
